# RadPi — Pi 5 Production Environment
# =====================================
# This file is written to /home/pi/radpi/.env.local by deploy.sh
# Do NOT commit secrets to git.

# ── Next.js server-side (server → FastAPI, stays on device) ────────────────
BACKEND_URL=http://127.0.0.1:8000

# ── Browser-side (browser → Next.js, goes over Wi-Fi) ──────────────────────
NEXT_PUBLIC_API_BASE_URL=http://10.42.0.1

# ── FastAPI CORS (which origins are allowed to call the backend) ─────────────
# Includes 10.42.0.1, radpi.local/lan/wifi/home (hotspot clients) and localhost (local dev/testing)
CORS_ALLOWED_ORIGINS=http://10.42.0.1,http://radpi.local,http://radpi.lan,http://radpi.wifi,http://radpi.home,http://localhost:3000,http://127.0.0.1:3000,http://localhost,http://127.0.0.1

# ── Node environment ─────────────────────────────────────────────────────────
NODE_ENV=production

# ── HuggingFace token (needed to download gated model weights) ───────────────
# Fill this in before running deploy.sh, or export HF_TOKEN in your shell
HF_TOKEN=

# ── Powerbank / low-power demo mode ──────────────────────────────────────────
# Set LOW_POWER=1 when running off a powerbank for demos.
# This drops LLM inference threads from 4→2 and batch size from 512→256,
# which prevents USB voltage sag from crashing the Pi 5 during inference.
# Inference will be ~1.5–2× slower but the Pi will stay stable.
LOW_POWER=1

# ── Local development ─────────────────────────────────────────────────────────
# URL of the FastAPI backend (used by the frontend to make API calls)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Backend URL for Next.js server-side rewrites
BACKEND_URL=http://127.0.0.1:8000

# HuggingFace token (required for gated model repos)
HF_TOKEN=

# Comma-separated origins the backend CORS policy allows
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Set to 'production' in deployment
NODE_ENV=development

# ── Raspberry Pi 5 hotspot deployment ────────────────────────────────────────
# Copy .env.pi to .env.local on the Pi, or run deploy.sh (it does this for you)
#
# BACKEND_URL=http://127.0.0.1:8000           # internal: Next.js → FastAPI (loopback)
# NEXT_PUBLIC_API_BASE_URL=http://radpi.local:3000
# CORS_ALLOWED_ORIGINS=http://radpi.local:3000,http://localhost:3000
# NODE_ENV=production
#
# The Wi-Fi hotspot (SSID: RadPi / pass: radpi1234) is toggled by long-pressing
# the Pi 5 power button. See HOTSPOT_SETUP.md for full instructions.
